extends layout

block content
  nav(style="background: #1A1A2E; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center;")
    span(style="font-family: Georgia, serif; font-size: 1.5rem; color: #F5F0E8;") BookShelf
    div(style="display: flex; align-items: center; gap: 1.5rem;")
      span(style="font-size: 0.8rem; color: #aaa;")
        | Connecté en tant que&nbsp;
        strong(style="color: #D4A017;")= user.username
      a(href="/auth/logout" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #C0392B; text-decoration: none; border: 1px solid #C0392B; padding: 0.4rem 0.8rem;") Déconnexion

  div(style="padding: 3rem 2rem 2rem; max-width: 1100px; margin: 0 auto;")
    p(style="font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; color: #C0392B; font-weight: 700; margin-bottom: 0.4rem;") Collection
    h1(style="font-family: Georgia, serif; font-size: 2.5rem; font-weight: 400; color: #1A1A2E;") Bibliothèque
    p(style="color: #666; margin-top: 0.5rem; font-size: 0.9rem;")= books.length + " livres disponibles"

  hr(style="border: none; border-top: 2px solid #1A1A2E; max-width: 1100px; margin: 0 auto 2.5rem;")

  div(style="display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 2rem; max-width: 1100px; margin: 0 auto; padding: 0 2rem 4rem;")
    each book in books
      div(style="cursor: pointer;")
        div(style="height: 220px; background: linear-gradient(135deg, #1A1A2E 0%, #2d3561 100%); border: 2px solid #1A1A2E; display: flex; align-items: center; justify-content: center; margin-bottom: 0.75rem; position: relative; overflow: hidden;")
          div(style="padding: 1rem; text-align: center;")
            p(style="font-family: Georgia, serif; font-size: 0.9rem; color: #F5F0E8; line-height: 1.3;")= book.title
            p(style="font-size: 0.65rem; color: #D4A017; margin-top: 0.5rem;")= book.author
        h3(style="font-size: 0.85rem; font-weight: 700; color: #1A1A2E; margin-bottom: 0.2rem;")= book.title
        p(style="font-size: 0.75rem; color: #666; margin-bottom: 0.2rem;")= book.author
        div(style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.3rem;")
          span(style="font-size: 0.65rem; padding: 0.15rem 0.5rem; background: #1A1A2E; color: #F5F0E8; font-weight: 700;")= book.genre
          span(style="font-size: 0.7rem; color: #999;")= book.year